{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@openfs/core": ["../core/src"],
      "@openfs/grep-optimizer": ["../grep-optimizer/src"]
    }
  },
  "include": ["src/index.ts", "src/adapter.ts"],
  "exclude": ["node_modules", "dist"]
}
