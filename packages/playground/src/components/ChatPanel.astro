---
---

<aside class="chat-panel">
  <div class="chat-header">
    <div class="chat-header-icon">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
    </div>
    <div>
      <div class="chat-title">OpenFS AI Assistant</div>
      <div class="chat-sub">Powered by Claude + OpenFS</div>
    </div>
  </div>

  <div class="chat-messages" id="chat-messages">
    <div class="msg assistant">
      <div class="bubble">
        Hi Derek! I can answer questions about your knowledge base, find articles, check sync status, or help you ingest content.
        <div class="bubble-actions">
          <button onclick="sendPreset('What pages are in the knowledge base?')">What pages exist?</button>
          <button onclick="sendPreset('What was recently added?')">Recent additions?</button>
        </div>
      </div>
    </div>
  </div>

  <div class="chat-footer">
    <div class="chat-input-wrap">
      <textarea
        id="chat-input"
        placeholder="Type a message..."
        rows="1"
        onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendMsg()}"
        oninput="this.style.height='auto';this.style.height=Math.min(this.scrollHeight,120)+'px'"
      ></textarea>
      <button class="send-btn" id="send-btn" onclick="sendMsg()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
      </button>
    </div>
    <div class="chat-hint">Enter to send</div>
  </div>
</aside>

<style>
  .chat-panel {
    width: 340px;
    border-left: 1px solid #e5e7eb;
    background: #ffffff;
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    height: 100%;
    min-height: 0;
  }
  .chat-header {
    padding: 1rem 1.1rem;
    border-bottom: 1px solid #f0f0f0;
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }
  .chat-header-icon {
    width: 30px;
    height: 30px;
    border-radius: 8px;
    background: #ede9fe;
    color: #6d28d9;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .chat-title { font-size: 0.84rem; font-weight: 600; color: #111827; }
  .chat-sub { font-size: 0.72rem; color: #9ca3af; margin-top: 0.05rem; }

  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .msg { display: flex; flex-direction: column; max-width: 92%; }
  .msg.user { align-self: flex-end; }
  .msg.assistant { align-self: flex-start; }

  .bubble {
    padding: 0.65rem 0.875rem;
    border-radius: 12px;
    font-size: 0.84rem;
    line-height: 1.55;
    color: #111827;
  }
  .msg.user .bubble { background: #6d28d9; color: white; border-bottom-right-radius: 3px; }
  .msg.assistant .bubble { background: #f9fafb; border: 1px solid #e5e7eb; border-bottom-left-radius: 3px; }

  .bubble-actions {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-top: 0.65rem;
  }
  .bubble-actions button {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    padding: 0.4rem 0.65rem;
    font-size: 0.78rem;
    color: #374151;
    cursor: pointer;
    text-align: left;
    transition: all 0.12s;
  }
  .bubble-actions button:hover { border-color: #6d28d9; color: #6d28d9; }

  .msg-citations {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-top: 0.4rem;
    padding: 0 0.1rem;
  }
  .cite-tag {
    font-size: 0.68rem;
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    background: #ede9fe;
    color: #6d28d9;
    border: 1px solid #ddd6fe;
  }

  .chat-footer {
    padding: 0.875rem 1rem;
    border-top: 1px solid #f0f0f0;
  }
  .chat-input-wrap {
    display: flex;
    align-items: flex-end;
    gap: 0.5rem;
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    padding: 0.5rem 0.6rem;
  }
  .chat-input-wrap:focus-within { border-color: #6d28d9; box-shadow: 0 0 0 3px rgba(109,40,217,0.08); }
  #chat-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    font-size: 0.84rem;
    color: #111827;
    resize: none;
    font-family: inherit;
    line-height: 1.4;
    min-height: 22px;
    max-height: 120px;
  }
  #chat-input::placeholder { color: #9ca3af; }
  .send-btn {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: #6d28d9;
    color: white;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .send-btn:hover { background: #5b21b6; }
  .send-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .chat-hint { font-size: 0.7rem; color: #d1d5db; text-align: center; margin-top: 0.4rem; }

  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: #e5e7eb; border-radius: 3px; }
</style>
