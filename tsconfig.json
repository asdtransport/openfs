{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["bun-types"],
    "paths": {
      "@openfs/core": ["./packages/core/src"],
      "@openfs/adapter-sqlite": ["./packages/adapter-sqlite/src"],
      "@openfs/grep-optimizer": ["./packages/grep-optimizer/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
